def binary_search(arr, n, target):
    l = 0
    r = n - 1
    pos = -1
    while l <= r:
        m = l + (r - l) // 2
        print(f"Median: {m}, nomor kursi: {arr[m]}")
        if arr[m] == target:
            pos = m
            break
        elif arr[m] < target:
            print("Mencari nomor kursi di kanan")
            l = m + 1
        else:
            print("Mencari nomor kursi di kiri")
            r = m - 1
    return pos


def main():
    try:
        n = int(input("Masukkan jumlah nomor kursi pesawat: "))
    except ValueError:
        print("Input tidak valid!")
        return
    arr = []
    print("Masukkan nomor kursi (urut menaik):")
    for i in range(n):
        while True:
            try:
                nilai = int(input())
                arr.append(nilai)
                break
            except ValueError:
                print("Input tidak valid, silakan masukkan angka!")
    print(f"Daftar nomor kursi: {arr}")
    while True:
        try:
            target = int(input("Masukkan nomor kursi yang ingin dicari: "))
            break
        except ValueError:
            print("Input tidak valid, silakan masukkan angka!")
    pos = binary_search(arr, n, target)
    if pos != -1:
        print(f"Nomor kursi ditemukan pada indeks ke-{pos}")
    else:
        print("Nomor kursi tidak ditemukan")


if __name__ == "__main__":
    main()
